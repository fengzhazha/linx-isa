{
  "$schema": "https://docs.openclaw.ai/schemas/linxisa/block_definition.v0.json",
  "descriptor_ownership": {
    "B.ARG": "Layout, format, transform, mode, and profile-specific arguments.",
    "B.DATR": "Data attributes: type extension, pad value, round mode, saturation, compare mode, byte id.",
    "B.DIM": "Matrix/CUBE dimensions when required by the opcode profile.",
    "B.IOD": "Dependency operands and dependency-domain records.",
    "B.IOR": "Scalar and memory operands.",
    "B.ITP": "Tile source operand binding and source reuse hints.",
    "B.META": "Element-domain shape, valid-region, and mask metadata through a GPR source.",
    "B.OTA": "Tile destination operand binding and destination allocation size.",
    "B.TEXT": "Out-of-line block body selection.",
    "BSTART": "Block class, operation selection, primary execution attributes.",
    "BSTOP": "Block termination."
  },
  "descriptor_sequence": [
    "BSTART.*",
    "block descriptors",
    "optional body selector or body records",
    "BSTOP"
  ],
  "headers": {
    "B.ITP": {
      "assembly": "B.ITP SrcTile0<.reuse>, SrcTile1<.reuse>, <last>, src_pair",
      "fields": [
        {
          "bits": "31:24",
          "name": "SrcTile1",
          "width": 8
        },
        {
          "bits": "23:16",
          "name": "SrcTile0",
          "width": 8
        },
        {
          "bits": "15",
          "name": "L",
          "width": 1
        },
        {
          "bits": "14:12",
          "fixed": "010",
          "name": "func",
          "width": 3
        },
        {
          "bits": "11:10",
          "name": "src_pair",
          "width": 2
        },
        {
          "bits": "9",
          "name": "S1R",
          "width": 1
        },
        {
          "bits": "8",
          "name": "S0R",
          "width": 1
        },
        {
          "bits": "7",
          "fixed": "0",
          "name": "reserved",
          "width": 1
        },
        {
          "bits": "6:4",
          "fixed": "001",
          "name": "group",
          "width": 3
        },
        {
          "bits": "3:1",
          "fixed": "001",
          "name": "group",
          "width": 3
        },
        {
          "bits": "0",
          "fixed": "1",
          "name": "length",
          "width": 1
        }
      ],
      "rules": [
        "src_pair selects operand slots src0/src1, src2/src3, src4/src5, or src6/src7.",
        "Unused source slots must encode TZERO.",
        "Any reuse bit attached to TZERO must be zero.",
        "If the block has no output tile descriptor, the final B.ITP must set L=1.",
        "B.ITP does not encode source size, dtype, layout, shape, memory operands, or dependency tokens."
      ]
    },
    "B.META": {
      "assembly": "B.META MetaGpr, MetaMode",
      "fields": [
        {
          "bits": "31:20",
          "fixed": "0x000",
          "name": "reserved",
          "width": 12
        },
        {
          "bits": "19:15",
          "name": "MetaGpr",
          "width": 5
        },
        {
          "bits": "14:12",
          "fixed": "100",
          "name": "func",
          "width": 3
        },
        {
          "bits": "11",
          "name": "MetaMode",
          "width": 1
        },
        {
          "bits": "10:7",
          "fixed": "0000",
          "name": "reserved",
          "width": 4
        },
        {
          "bits": "6:4",
          "fixed": "100",
          "name": "group",
          "width": 3
        },
        {
          "bits": "3:1",
          "fixed": "001",
          "name": "group",
          "width": 3
        },
        {
          "bits": "0",
          "fixed": "1",
          "name": "length",
          "width": 1
        }
      ],
      "meta_modes": {
        "0": "meta_shape",
        "1": "meta_mask"
      },
      "meta_shape_payload": [
        {
          "bits": "3:0",
          "name": "format",
          "width": 4
        },
        {
          "bits": "7:4",
          "name": "logR",
          "width": 4
        },
        {
          "bits": "11:8",
          "name": "logC",
          "width": 4
        },
        {
          "bits": "13:12",
          "name": "vmode",
          "width": 2
        },
        {
          "bits": "27:14",
          "name": "valid.R",
          "width": 14
        },
        {
          "bits": "41:28",
          "name": "valid.C",
          "width": 14
        },
        {
          "bits": "45:42",
          "name": "off.R",
          "width": 4
        },
        {
          "bits": "49:46",
          "name": "off.C",
          "width": 4
        },
        {
          "bits": "57:50",
          "name": "mask_tile",
          "width": 8
        },
        {
          "bits": "63:58",
          "fixed": "000000",
          "name": "reserved",
          "width": 6
        }
      ],
      "rules": [
        "MetaGpr is an ordinary GPR source and participates in scalar rename/read/RAW dependency handling.",
        "MetaMode=meta_shape describes element-domain shape, valid rectangle, and optional mask tile id.",
        "MetaMode=meta_mask is reserved unless an opcode profile explicitly defines its payload.",
        "B.META does not carry dtype, layout, pad, round, saturation, byte id, memory base/stride, scalar operands, quantization operands, or dependency token fields."
      ]
    },
    "B.OTA": {
      "assembly": "B.OTA ->DstTile<CellCountM1>, <last>, dst_slot",
      "cell_count_rule": "CELL_count = CellCountM1 + 1; TileBytes = CELL_count * 128.",
      "fields": [
        {
          "bits": "31:24",
          "name": "DstTile",
          "width": 8
        },
        {
          "bits": "23:16",
          "name": "CellCountM1",
          "width": 8
        },
        {
          "bits": "15",
          "name": "L",
          "width": 1
        },
        {
          "bits": "14:12",
          "fixed": "011",
          "name": "func",
          "width": 3
        },
        {
          "bits": "11:10",
          "name": "dst_slot",
          "width": 2
        },
        {
          "bits": "9:7",
          "fixed": "000",
          "name": "reserved",
          "width": 3
        },
        {
          "bits": "6:4",
          "fixed": "001",
          "name": "group",
          "width": 3
        },
        {
          "bits": "3:1",
          "fixed": "001",
          "name": "group",
          "width": 3
        },
        {
          "bits": "0",
          "fixed": "1",
          "name": "length",
          "width": 1
        }
      ],
      "rules": [
        "DstTile=TZERO is illegal.",
        "dst_slot selects output slots dst0..dst3.",
        "For same-shape elementwise ops, CellCountM1 must match all source TileReg allocation sizes.",
        "For convert, reduce, expand, and matrix-like ops, opcode profile rules define legal source and destination size relationships."
      ]
    }
  },
  "isa": "LinxISA",
  "status": "proposed",
  "tile_register_namespace": {
    "ordinary_range": {
      "end": 255,
      "start": 1
    },
    "tzero": {
      "code": 0,
      "destination_allowed": false,
      "source_allowed": true
    },
    "width_bits": 8
  },
  "version": "0.57.0"
}
