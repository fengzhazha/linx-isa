        "name": "EBARG_UQ1_ACRn",
        "width_bits": 64
      },
      {
        "access": "RW",
        "description": "U-hand queue entry 2.",
        "idx": "0xF4B",
        "name": "EBARG_UQ2_ACRn",
        "width_bits": 64
      },
      {
        "access": "RW",
        "description": "U-hand queue entry 3.",
        "idx": "0xF4C",
        "name": "EBARG_UQ3_ACRn",
        "width_bits": 64
      },
      {
        "access": "RW",
        "description": "Packed LB0..LB2 as 16-bit each (low bits).",
        "idx": "0xF4D",
        "name": "EBARG_LB_ACRn",
        "width_bits": 64
      },
      {
        "access": "RW",
        "description": "Packed LC0..LC2 as 16-bit each (low bits).",
