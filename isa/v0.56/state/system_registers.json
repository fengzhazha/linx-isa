    "fields": [
      {
        "description": "Asynchronous interrupt indicator (1=async interrupt, 0=sync fault/trap).",
        "lsb": 63,
        "msb": 63,
        "name": "E"
      },
      {
        "description": "TRAPARG0 valid (1=valid).",
        "lsb": 62,
        "msb": 62,
        "name": "ARGV"
      },
      {
        "description": "Sub-cause encoding (profile-defined per TRAPNUM).",
        "lsb": 24,
        "msb": 47,
        "name": "CAUSE"
      },
      {
        "description": "Trap major class (6-bit).",
        "lsb": 0,
        "msb": 5,
        "name": "TRAPNUM"
      }
    ],
    "notes": [
      "TRAPNO is shared for faults, traps, and interrupts.",
      "E=1 indicates asynchronous interrupt; E=0 indicates synchronous fault/trap.",
      "ARGV=1 indicates TRAPARG0 is valid."
    ]
  },
