      {
        "description": "Interrupt class (E=1, TRAPARG0=irq_id).",
        "name": "INTERRUPT",
        "trapnum": 44
      },
      {
        "description": "Hardware breakpoint trap.",
        "name": "HW_BREAKPOINT",
        "trapnum": 49
      },
      {
        "description": "Software breakpoint trap (EBREAK).",
        "name": "SW_BREAKPOINT",
        "trapnum": 50
      },
      {
        "description": "Hardware watchpoint trap.",
        "name": "HW_WATCHPOINT",
        "trapnum": 51
